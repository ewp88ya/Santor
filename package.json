{
  "name": "santor",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "lint": "pnpm --filter @santor/web lint && pnpm --filter @santor/admin lint",
    "build": "pnpm --filter @santor/web build && pnpm --filter @santor/admin build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.63.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm exec eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  }
}
